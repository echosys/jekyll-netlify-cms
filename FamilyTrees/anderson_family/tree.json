    },
    {
      "id": "980482ce-6089-4401-833e-36c66d7626eb",
      "name": "Clara Anderson",
      "birth_date": "1990-03-25",
      "death_date": null,
      "gender": "female",
      "bio": "Clara is a medical resident at Johns Hopkins Hospital, specialising in geriatrics. She plays violin in a local chamber orchestra and volunteers at a free clinic on weekends.",
      "profile_image_ref": "resources/1990-clara_anderson.jpg",
      "is_standalone": false,
      "position": {
