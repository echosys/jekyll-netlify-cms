  "nodes": [
    {
      "id": "eb25d503-8441-4924-80e0-64b4ce121a48",
      "name": "George Anderson",
      "birth_date": "1935-04-12",
      "death_date": "2010-11-03",
      "gender": "male",
      "bio": "George was a carpenter and community leader who built the family home in Vermont. He served in the Korean War and was known for his woodworking and love of fishing. He was an elder at the local church for over 30 years.",
      "profile_image_ref": "resources/1935-george_anderson.jpg",
      "is_standalone": false,
      "position": {
        "x": 400.0,
        "y": 60.0
      },
      "links": []
    },
    {
      "id": "5ed40e84-0a13-46c1-b9f9-c520d146638e",
      "name": "Eleanor Anderson",
      "birth_date": "1940-08-22",
      "death_date": null,
      "gender": "female",
      "bio": "Eleanor is a retired schoolteacher who taught elementary school for 35 years in Burlington. She is an avid gardener and hosts the annual family reunion every summer. She has been learning watercolour painting since retirement.",
      "profile_image_ref": "resources/1940-eleanor_anderson.jpg",
      "is_standalone": false,
      "position": {
        "x": 640.0,
        "y": 60.0
      },
      "links": []
    },
    {
      "id": "a3d25801-9b65-4002-9d90-4cb1eed8caf7",
      "name": "Thomas Anderson",
      "birth_date": "1962-02-14",
      "death_date": null,
      "gender": "male",
      "bio": "Thomas is a civil engineer based in Boston, specialising in bridge design. He and his wife Margaret have two children, Robert and Clara. He coaches youth soccer on weekends and is a passionate fly-fisherman.",
      "profile_image_ref": "resources/1962-thomas_anderson.jpg",
      "is_standalone": false,
      "position": {
        "x": 160.0,
        "y": 280.0
      },
      "links": []
    },
    {
      "id": "b4a99f6f-0f7f-493d-be0a-fed4123eab8d",
      "name": "Margaret Anderson",
      "birth_date": "1964-07-30",
      "death_date": null,
      "gender": "female",
      "bio": "Margaret is a pediatric nurse at Boston Children's Hospital. She grew up in Portland, Maine and met Thomas at UVM. She has climbed all 48 New Hampshire 4000-footers and is training for her first marathon.",
      "profile_image_ref": "resources/1964-margaret_anderson.jpg",
      "is_standalone": false,
      "position": {
        "x": 400.0,
        "y": 280.0
      },
      "links": []
    },
    {
      "id": "d6a555d9-75c5-4b00-9000-101cf8b42c9d",
      "name": "Alice Anderson",
      "birth_date": "1965-12-05",
      "death_date": null,
      "gender": "female",
      "bio": "Alice is a graphic designer and the youngest child of George and Eleanor. She lives in Portland, Oregon, and specialises in book-cover and editorial design. Her son Henry inherited her eye for visual storytelling.",
      "profile_image_ref": "resources/1965-alice_anderson.jpg",
      "is_standalone": false,
      "position": {
        "x": 700.0,
        "y": 280.0
      },
      "links": []
    },
    {
      "id": "87a31dc6-26f5-4fe2-8311-3db6b330f8b1",
      "name": "Robert Anderson",
      "birth_date": "1988-09-17",
      "death_date": null,
      "gender": "male",
      "bio": "Robert is a senior software engineer at a Bay Area startup. He is the eldest child of Thomas and Margaret. Outside work he brews his own beer and volunteers at a local food bank.",
      "profile_image_ref": "resources/1988-robert_anderson.jpg",
      "is_standalone": false,
      "position": {
        "x": 80.0,
        "y": 500.0
