{
  "name": "picasa-electron",
  "version": "0.1.0",
  "private": true,
  "description": "Electron port of the Photo Manager with backup features",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "vite",
    "build:renderer": "vite build --outDir dist/renderer",
    "build": "tsc -p tsconfig.json && npm run build:renderer",
    "start": "electron .",
    "start:dev": "ELECTRON_DEV=1 electron . --remote-allow-origins=http://localhost:9222",
    "start:inspect": "electron --inspect=9229 .",
    "test": "node tests/test_split_logic.js && node tests/test_diff.js"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "vite": "^5.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "@types/node": "^20.0.0",
    "@types/archiver": "^5.1.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0"
  },
  "dependencies": {
    "electron": "^26.0.0",
    "archiver": "^5.3.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
