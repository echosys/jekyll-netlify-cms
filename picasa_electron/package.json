{
  "name": "picasa-electron",
  "version": "0.1.0",
  "private": true,
  "description": "Electron port of the Photo Manager with backup features",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "vite",
    "build:renderer": "vite build",
    "build": "tsc -p tsconfig.json && npm run build:renderer",
    "start": "electron .",
    "start:dev": "ELECTRON_DEV=1 electron . --remote-allow-origins=http://localhost:9222",
    "start:inspect": "electron --inspect=9229 .",
    "test": "node tests/test_split_logic.js && node tests/test_diff.js"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.3",
    "@types/archiver": "^5.1.0",
    "@types/better-sqlite3": "^7.6.0",
    "@types/leaflet": "^1.9.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "adm-zip": "^0.5.16",
    "archiver": "^5.3.0",
    "axios": "^1.5.0",
    "better-sqlite3": "^12.8.0",
    "date-fns": "^2.30.0",
    "electron": "^26.0.0",
    "exiftool-vendored": "^23.0.0",
    "framer-motion": "^10.16.4",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.263.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-leaflet": "^4.2.1",
    "sharp": "^0.32.0"
  }
}
