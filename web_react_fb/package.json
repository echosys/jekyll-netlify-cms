{
  "name": "web_react",
  "private": true,
  "version": "0.0.0",
  "engines": {
    "node": ">=20.x"
  },
  "scripts": {
    "dev": "vite",
    "dev:fs": "tsx api/fs-server.ts",
    "kill:fs": "lsof -ti:3001 | xargs kill -9 2>/dev/null || true",
    "predev:all": "npm run kill:fs",
    "dev:all": "concurrently \"npm run dev:fs\" \"npm run dev\"",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "emulators": "firebase emulators:start --only firestore,auth,storage",
    "migrate:resource-sizes": "node scripts/update-resource-sizes.mjs"
  },
  "dependencies": {
    "@dagrejs/dagre": "^2.0.4",
    "@tailwindcss/vite": "^4.2.1",
    "@xyflow/react": "^12.10.1",
    "firebase": "^11.10.0",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.13.1",
    "tailwindcss": "^4.2.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@firebase/rules-unit-testing": "^4.0.1",
    "@types/dagre": "^0.7.54",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.1",
    "@types/pg": "^8.18.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vercel/node": "^5.6.11",
    "@vitejs/plugin-react": "^5.1.1",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "firebase-admin": "^11.11.1",
    "firebase-tools": "^15.10.0",
    "globals": "^16.5.0",
    "mocha": "^11.7.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1"
  }
}
